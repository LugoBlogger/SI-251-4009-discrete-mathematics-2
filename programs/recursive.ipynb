    "factorial using iteration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "0931f60a",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "24"
      ]
     },
     "execution_count": 15,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def func(x):\n",
    "  out = 1\n",
    "  for i in range(x, 1, -1):\n",
    "    out *= i  # x = x * i\n",
    "  \n",
    "  return out\n",
    "\n",
    "func(4)"
   ]
  }
